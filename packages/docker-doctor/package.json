{
  "name": "docker-doctor",
  "version": "0.0.0",
  "description": "Static analysis for Dockerfile and Docker Compose files",
  "keywords": [
    "best-practices",
    "diagnostics",
    "docker",
    "docker-compose",
    "dockerfile",
    "linter",
    "performance",
    "security"
  ],
  "homepage": "https://github.com/PunGrumpy/docker-doctor#readme",
  "bugs": {
    "url": "https://github.com/PunGrumpy/docker-doctor/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Noppakorn Kaewsalabnil",
    "url": "https://www.pungrumpy.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PunGrumpy/docker-doctor.git",
    "directory": "packages/docker-doctor"
  },
  "bin": {
    "docker-doctor": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "NODE_OPTIONS='--max-old-space-size=4096' tsdown",
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "git clean -xdf .turbo node_modules dist"
  },
  "dependencies": {
    "@docker-doctor/core": "workspace:*",
    "chalk": "^5.4.1",
    "commander": "^15.0.0",
    "effect": "4.0.0-beta.70",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^26",
    "tsdown": "^0.22.4",
    "typescript": "^6"
  }
}
